# ─── TMDB ────────────────────────────────────────────────────────────────────
# Get your Read Access Token at https://www.themoviedb.org/settings/api
# Use the "API Read Access Token (v4 auth)" — NOT the v3 API key
TMDB_ACCESS_TOKEN=

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate a secure secret: npx auth secret
AUTH_SECRET=
# Base URL for Auth.js callbacks — defaults to localhost:3000, change for custom domains
AUTH_URL=http://localhost:3000

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# https://console.cloud.google.com → Create credentials → OAuth client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth (optional) ─────────────────────────────────────────────────
# https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
